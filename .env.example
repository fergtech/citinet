# Citinet Hub Configuration
# Copy this file to .env and update values for your hub

# Hub Identity
HUB_NAME=My Community Hub
HUB_SLUG=mycommunity
HUB_LOCATION=Los Angeles, CA
HUB_DESCRIPTION=A local community hub for sharing resources and connecting neighbors

# Hub Visibility
# Options: public, community, private
HUB_VISIBILITY=public

# API Configuration
API_PORT=9090

# Database Configuration
DB_PASSWORD=changeme_strong_password_here

# Data Directory — where ALL hub data (database, files, cache) is stored on this machine.
# Change this to any path on any drive you control, e.g.:
#   Windows: D:\my-hub-data
#   Linux:   /mnt/external-drive/citinet
# Default (if left blank): a ./data folder next to this file.
DATA_DIR=./data

# Storage Configuration (MinIO S3-compatible)
STORAGE_ACCESS_KEY=changeme_access_key
STORAGE_SECRET_KEY=changeme_secret_key_at_least_32_chars
STORAGE_BUCKET=hub-files

# Redis Configuration
REDIS_PASSWORD=changeme_redis_password

# Security
JWT_SECRET=changeme_jwt_secret_at_least_64_characters_long_random_string

# CORS (for browser access)
# Use * for development, specific domain for production
CORS_ORIGIN=*

# Tunnel Configuration (Optional - configure after hub is running)
# Your public URL via Tailscale Funnel, Cloudflare Tunnel, etc.
TUNNEL_URL=

# Registry Configuration (Optional - for hub discovery)
# Leave empty to skip automatic registration
REGISTRY_URL=

# Advanced Options
# NODE_ENV=production
# LOG_LEVEL=info
# MAX_FILE_SIZE=100MB
# SESSION_TIMEOUT=24h
